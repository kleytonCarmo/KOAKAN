# Credenciais do app Whoop (pegue no Developer Dashboard do Whoop)
# NUNCA suba o arquivo .env real pro GitHub — só este .env.example.
WHOOP_CLIENT_ID=seu_client_id_aqui
WHOOP_CLIENT_SECRET=seu_client_secret_aqui

# Segredo pra assinar o cookie de sessão. Gere um valor aleatório longo.
# Ex. (terminal): openssl rand -hex 32
AXON_COOKIE_SECRET=troque_por_um_valor_aleatorio_longo

# URL pública do app já publicado (sem barra no final).
# Em desenvolvimento local: http://localhost:5173
APP_URL=http://localhost:5173
